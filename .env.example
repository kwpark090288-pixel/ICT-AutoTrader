# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Postgres (Prisma)
DATABASE_URL=postgresql://trader:trader_pass@localhost:5432/trading_dashboard?schema=public

# Runtime
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT
TF_SET=D1,H4,H1,M30,M15,M5
D1_DAYKEY_TZ=UTC

# Lookback (candles per symbol×TF)
LOOKBACK_D1=400
LOOKBACK_H4=600
LOOKBACK_H1=1000
LOOKBACK_M30=1200
LOOKBACK_M15=1500
LOOKBACK_M5=3000