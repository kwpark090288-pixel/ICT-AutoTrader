datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum TelegramOutboxStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

enum TradePlanStatus {
  OPEN
  CLOSING
  CLOSED
}

model TelegramOutbox {
  id             String               @id @default(uuid())
  idempotencyKey String               @unique @map("idempotency_key")
  messageType    String               @map("message_type")
  planId         String?              @map("plan_id")
  symbol         String?
  tf             String?
  direction      String?
  payloadText    String               @map("payload_text")
  status         TelegramOutboxStatus @default(PENDING)
  attemptCount   Int                  @default(0) @map("attempt_count")
  nextAttemptAt  DateTime             @default(now()) @map("next_attempt_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  sentAt         DateTime?            @map("sent_at")
  lastError      String?              @map("last_error")
  tgMessageId    String?              @map("tg_message_id")

  @@index([status, nextAttemptAt])
  @@map("telegram_outbox")
}

model TradePlan {
  planId          String          @id @default(uuid()) @map("plan_id")
  planKey         String          @unique @map("plan_key")
  tradeKey        String          @map("trade_key")
  zoneKey         String          @map("zone_key")
  status          TradePlanStatus @default(OPEN)
  symbol          String
  tf              String?
  direction       String?
  source          String?
  poiTier         String?         @map("poi_tier")
  poiId           String?         @map("poi_id")
  eventType       String?         @map("event_type")
  riskPctAtOpen   Float?          @map("risk_pct_at_open")
  edgeSigFine     String?         @map("edge_sig_fine")
  edgeSigMid      String?         @map("edge_sig_mid")
  edgeSigCoarse   String?         @map("edge_sig_coarse")
  rAfterCost      Float?          @map("r_after_cost")
  poiClusterKey   String?         @map("poi_cluster_key")
  poiHighlightJson Json?          @map("poi_highlight_json")
  planJson        Json?           @map("plan_json")
  openedAt        DateTime        @default(now()) @map("opened_at")
  closedAt        DateTime?       @map("closed_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([symbol, status, openedAt])
  @@index([tradeKey, status])
  @@index([status, openedAt])
  @@index([status, closedAt])
  @@map("trade_plans")
}

model EdgeStat {
  signatureType String   @map("signature_type")
  signatureKey  String   @map("signature_key")
  n             Int      @default(0)
  meanR         Float    @default(0) @map("mean_r")
  stdR          Float    @default(0) @map("std_r")
  m2            Float    @default(0)
  updatedAtUtc  DateTime @map("updated_at_utc")

  @@id([signatureType, signatureKey])
  @@index([signatureType, updatedAtUtc])
  @@map("edge_stats")
}

model ConcentrationHistory {
  id           String   @id @default(uuid())
  candidateId  String   @map("candidate_id")
  tradeKey     String   @map("trade_key")
  symbol       String
  dir          String
  clusterKey   String   @map("cluster_key")
  source       String
  poiTier      String   @map("poi_tier")
  openTimeUtc  DateTime @map("open_time_utc")
  createdAtUtc DateTime @default(now()) @map("created_at_utc")

  @@unique([tradeKey, openTimeUtc, clusterKey])
  @@index([symbol, dir, openTimeUtc])
  @@index([clusterKey, openTimeUtc])
  @@map("concentration_history")
}

model PolicyAccountState {
  profileId            String   @map("profile_id")
  scope                String
  riskMode             String   @map("risk_mode")
  updatedAtUtc         DateTime @map("updated_at_utc")
  lastTransitionReason String?  @map("last_transition_reason")

  @@id([profileId, scope])
  @@map("policy_account_state")
}

model PolicyDecisionLog {
  candidateId        String   @id @map("candidate_id")
  tradeKey           String   @map("trade_key")
  symbol             String
  dir                String
  clusterKey         String?  @map("cluster_key")
  source             String
  poiTier            String   @map("poi_tier")
  eventType          String   @map("event_type")
  decision           String
  scoreDeltaSum      Float    @default(0) @map("score_delta_sum")
  policyTagsJson     Json?    @map("policy_tags_json")
  reasonsJson        Json?    @map("reasons_json")
  evidenceLevel      String?  @map("evidence_level")
  usedSignature      String?  @map("used_signature")
  riskMode           String   @map("risk_mode")
  suggestedRiskPct   Float    @default(0) @map("suggested_risk_pct")
  openTimeUtc        DateTime @map("open_time_utc")
  createdAtUtc       DateTime @default(now()) @map("created_at_utc")
  updatedAtUtc       DateTime @updatedAt @map("updated_at_utc")

  @@index([openTimeUtc, source, decision])
  @@index([symbol, dir, openTimeUtc])
  @@index([tradeKey, openTimeUtc])
  @@map("policy_decision_log")
}

model SignalEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  symbol    String?
  tf        String?
  eventText String   @map("event_text")

  @@index([createdAt])
  @@index([symbol, tf, createdAt])
  @@map("signals")
}

model SeenState {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  eventId   String   @map("event_id")
  seenAtUtc DateTime @map("seen_at_utc")

  @@unique([profileId, eventId])
  @@map("seen_state")
}

model MuteState {
  id           String    @id @default(uuid())
  profileId    String    @map("profile_id")
  symbol       String
  tf           String
  direction    String?
  muteUntilUtc DateTime? @map("mute_until_utc")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([profileId, symbol, tf, direction])
  @@map("mute_state")
}

model SystemState {
  scopeKey    String   @id @map("scope_key") // use "GLOBAL"
  syncing     Boolean  @default(true)
  dataOk      Boolean  @default(false) @map("data_ok")
  gapDetected Boolean  @default(false) @map("gap_detected")
  updatedAt   DateTime @updatedAt @map("updated_at")
  details     Json?    @map("details_json")

  @@map("system_state")
}

model ReviewNote {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  noteText  String   @map("note_text")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([planId, createdAt])
  @@map("review_notes")
}

model SoundPreference {
  id           String   @id @default(uuid())
  profileId    String   @unique @map("profile_id")
  enabled      Boolean  @default(false)
  updatedAtUtc DateTime @map("updated_at_utc")

  @@map("sound_preferences")
}

model SoundPlayed {
  id          String   @id @default(uuid())
  profileId   String   @map("profile_id")
  eventId     String   @map("event_id")
  playedAtUtc DateTime @map("played_at_utc")

  @@unique([profileId, eventId])
  @@map("sound_played")
}
